{
  "name": "growth-app",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview --host",
    "icons": "node scripts/generate-icons.mjs",
    "sync:plans": "VITE_SUPABASE_URL=$npm_config_supabase_url VITE_SUPABASE_ANON_KEY=$npm_config_supabase_anon_key VITE_SYNC_EMAIL=$npm_config_sync_email VITE_SYNC_PASSWORD=$npm_config_sync_password npx tsx scripts/sync-plans.ts",
    "sync:plans:local": "test -f .env.local && export $(cat .env.local | xargs) && npx tsx scripts/sync-plans.ts || echo '请先创建 .env.local'"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.110.0",
    "pinia": "^2.3.0",
    "suncalc": "^2.0.0",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@vitejs/plugin-vue": "^5.2.1",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "sharp": "^0.35.3",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.23.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.5",
    "vite-plugin-pwa": "^0.21.1",
    "vue-tsc": "^2.2.0"
  }
}
