# Supabase（必填 — 从 Supabase 项目 Settings → API 获取）
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_your_anon_key

# Sync 账号（Obsidian 同步用 — 你的 Supabase 登录邮箱和密码）
VITE_SYNC_EMAIL=your@email.com
VITE_SYNC_PASSWORD=your_password

# 将以上内容复制到 .env.local 填写真实值（.env.local 已在 .gitignore 中）
